# =============================================
# Unalone 프로덕션 환경 설정
# 이 파일을 프로젝트 루트에 .env로 복사 후 값을 입력하세요
# cp infra/env-templates/.env.prod.template .env
# =============================================

# ===== 도메인 & SSL =====
DOMAIN=unalone.example.com       # 실제 도메인으로 변경
ACME_EMAIL=admin@example.com     # Let's Encrypt 인증서 이메일

# ===== PostgreSQL =====
POSTGRES_DB=project_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                # 강력한 비밀번호 입력 (필수)

# ===== MongoDB =====
MONGO_USER=mongo
MONGO_PASSWORD=                   # 강력한 비밀번호 입력 (필수)
MONGO_DATABASE=project_db

# ===== JWT =====
JWT_SECRET=                       # 최소 32바이트 랜덤 문자열 (필수)

# ===== Grafana =====
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=           # 강력한 비밀번호 입력 (필수)
