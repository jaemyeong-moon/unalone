# =============================================
# Unalone 서비스 환경 설정 템플릿
# 이 파일을 복사하여 .env로 저장 후 값을 입력하세요
# cp .env.template .env
# =============================================

# ===== PostgreSQL =====
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=project_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=               # 반드시 변경

# ===== MongoDB =====
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=mongo
MONGO_PASSWORD=                  # 반드시 변경
MONGO_DATABASE=project_db

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== JWT =====
JWT_SECRET=                      # 최소 32바이트, 반드시 변경

# ===== 도메인/네트워크 =====
DOMAIN=localhost
API_SERVICE_URL=http://api-service:8080
ADMIN_SERVICE_URL=http://admin-service:8081
EVENT_SERVICE_URL=http://event-service:8082

# ===== Grafana =====
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=          # 반드시 변경
